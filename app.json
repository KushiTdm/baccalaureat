{
  "expo": {
    "name": "Petit bac",
    "slug": "bolt-expo-nativewind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "L'application a besoin du Bluetooth pour le mode multijoueur",
        "NSBluetoothPeripheralUsageDescription": "L'application a besoin du Bluetooth pour se connecter aux autres joueurs"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "munim-bluetooth",
        {
          "androidBluetoothPermissions": [
            "scan",
            "connect",
            "advertise"
          ]
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "userTrackingUsageDescription": "Cet identifiant sera utilisé pour vous proposer des publicités personnalisées."
        }
      ],
      "expo-audio",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.2.20"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e7f58748-e4a4-4dc9-9bdd-b7c05134264c"
      },
      "EXPO_PUBLIC_SUPABASE_URL": "https://wuubarlhzvpvybxwslac.supabase.co",
